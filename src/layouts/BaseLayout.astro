---
// Faithful chrome from the original Elementor site. Header/footer/scripts and the
// vendored CSS are mirrored verbatim; pages provide their own per-page inline
// styles (headExtra) and body content via the default slot.
import headLinks from '../mirror/head-links.html?raw';
import headerHome from '../mirror/header-home.html?raw';
import headerInner from '../mirror/header-inner.html?raw';
import footerHtml from '../mirror/footer.html?raw';
import scriptsHtml from '../mirror/scripts.html?raw';

interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
  headerVariant?: 'home' | 'inner';
  headExtra?: string;
  ogImage?: string;
}
const {
  title,
  description = '科学技術を実装し、より豊かな『現実』を発見するためのギルド',
  bodyClass = '',
  headerVariant = 'inner',
  headExtra = '',
  ogImage,
} = Astro.props;

const header = headerVariant === 'home' ? headerHome : headerInner;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---
<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="ja_JP" />
    {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site).href} />}
    <meta name="twitter:card" content="summary_large_image" />
    <Fragment set:html={headLinks} />
    {headExtra && <Fragment set:html={headExtra} />}
  </head>
  <body class={bodyClass}>
    <Fragment set:html={header} />
    <slot />
    <Fragment set:html={footerHtml} />
    <Fragment set:html={scriptsHtml} />
  </body>
</html>
